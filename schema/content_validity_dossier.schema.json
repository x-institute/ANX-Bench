{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anx-bench.org/schema/content_validity_dossier.schema.json",
  "title": "ANX-Bench Content Validity Dossier Schema",
  "description": "Machine-readable dossier for expert content-validity review before an ANX-Bench item set can move to approved_scored.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "dossier_schema_version",
    "dossier_id",
    "benchmark_version",
    "dossier_status",
    "construct_id",
    "construct_definition",
    "intended_scored_use",
    "target_population",
    "review_protocol_path",
    "item_ids",
    "domain_facets",
    "reviewer_panel",
    "item_reviews",
    "scale_level_cvi",
    "revision_decisions",
    "promotion_eligibility",
    "signoff"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "promotion_eligibility": {
            "properties": {
              "scored_promotion_eligible": {
                "const": true
              }
            },
            "required": [
              "scored_promotion_eligible"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "reviewer_panel": {
            "properties": {
              "reviewer_count": {
                "minimum": 3
              },
              "independent_reviewer_count": {
                "minimum": 3
              }
            }
          },
          "item_reviews": {
            "items": {
              "properties": {
                "overall_item_cvi": {
                  "minimum": 0.78
                },
                "construct_overlap_flag": {
                  "enum": [
                    "none",
                    "resolved"
                  ]
                },
                "reading_level_flag": {
                  "enum": [
                    "none",
                    "resolved"
                  ]
                },
                "harm_ethics_flag": {
                  "enum": [
                    "none",
                    "resolved"
                  ]
                }
              }
            }
          },
          "scale_level_cvi": {
            "properties": {
              "scale_cvi_average": {
                "minimum": 0.9
              },
              "all_required_facets_covered": {
                "const": true
              },
              "unresolved_construct_overlap_count": {
                "const": 0
              },
              "unresolved_reading_level_count": {
                "const": 0
              },
              "unresolved_harm_ethics_count": {
                "const": 0
              }
            }
          },
          "promotion_eligibility": {
            "properties": {
              "minimum_independent_reviewers_met": {
                "const": true
              },
              "all_item_cvi_thresholds_met": {
                "const": true
              },
              "scale_cvi_threshold_met": {
                "const": true
              },
              "construct_overlap_resolved": {
                "const": true
              },
              "reading_level_resolved": {
                "const": true
              },
              "harm_ethics_resolved": {
                "const": true
              }
            }
          },
          "signoff": {
            "properties": {
              "content_validity_decision": {
                "const": "approved_for_psychometric_promotion_review"
              }
            }
          }
        }
      }
    }
  ],
  "properties": {
    "$schema": {
      "$ref": "#/$defs/repository_path"
    },
    "dossier_schema_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "dossier_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(_[a-z0-9]+)*$"
    },
    "benchmark_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "dossier_status": {
      "type": "string",
      "enum": [
        "preregistered_template",
        "in_review",
        "completed",
        "superseded",
        "blocked"
      ]
    },
    "construct_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(_[a-z0-9]+)*$"
    },
    "construct_definition": {
      "type": "string",
      "minLength": 40
    },
    "intended_scored_use": {
      "type": "string",
      "minLength": 40
    },
    "target_population": {
      "type": "string",
      "minLength": 20
    },
    "review_protocol_path": {
      "$ref": "#/$defs/repository_path"
    },
    "item_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(_[a-z0-9]+)*$"
      }
    },
    "domain_facets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "facet_id",
          "facet_label",
          "facet_definition",
          "required_for_scored_promotion",
          "mapped_item_ids"
        ],
        "properties": {
          "facet_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(_[a-z0-9]+)*$"
          },
          "facet_label": {
            "type": "string",
            "minLength": 3
          },
          "facet_definition": {
            "type": "string",
            "minLength": 30
          },
          "required_for_scored_promotion": {
            "type": "boolean"
          },
          "mapped_item_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(_[a-z0-9]+)*$"
            }
          }
        }
      }
    },
    "reviewer_panel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewer_count",
        "independent_reviewer_count",
        "minimum_independent_reviewers_required",
        "independence_rule",
        "reviewers"
      ],
      "properties": {
        "reviewer_count": {
          "type": "integer",
          "minimum": 0
        },
        "independent_reviewer_count": {
          "type": "integer",
          "minimum": 0
        },
        "minimum_independent_reviewers_required": {
          "type": "integer",
          "const": 3
        },
        "independence_rule": {
          "type": "string",
          "minLength": 40
        },
        "reviewers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "reviewer_id",
              "expertise_area",
              "independent",
              "conflict_of_interest_statement",
              "review_completed"
            ],
            "properties": {
              "reviewer_id": {
                "type": "string",
                "pattern": "^[a-z0-9]+(_[a-z0-9]+)*$"
              },
              "expertise_area": {
                "type": "string",
                "minLength": 10
              },
              "independent": {
                "type": "boolean"
              },
              "conflict_of_interest_statement": {
                "type": "string",
                "minLength": 10
              },
              "review_completed": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "item_reviews": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item_id",
          "item_version",
          "primary_facet_id",
          "secondary_facet_ids",
          "reviewer_ratings",
          "criterion_cvi",
          "overall_item_cvi",
          "construct_overlap_flag",
          "reading_level_flag",
          "harm_ethics_flag",
          "required_revision"
        ],
        "properties": {
          "item_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(_[a-z0-9]+)*$"
          },
          "item_version": {
            "type": "string",
            "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
          },
          "primary_facet_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(_[a-z0-9]+)*$"
          },
          "secondary_facet_ids": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(_[a-z0-9]+)*$"
            }
          },
          "reviewer_ratings": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/reviewer_rating"
            }
          },
          "criterion_cvi": {
            "$ref": "#/$defs/criterion_cvi"
          },
          "overall_item_cvi": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 1
          },
          "construct_overlap_flag": {
            "$ref": "#/$defs/resolution_flag"
          },
          "reading_level_flag": {
            "$ref": "#/$defs/resolution_flag"
          },
          "harm_ethics_flag": {
            "$ref": "#/$defs/resolution_flag"
          },
          "required_revision": {
            "type": "string",
            "enum": [
              "none",
              "minor",
              "major",
              "exclude",
              "pending_review"
            ]
          }
        }
      }
    },
    "scale_level_cvi": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "calculation_rule",
        "scale_cvi_average",
        "scale_cvi_universal_agreement",
        "minimum_item_cvi_required",
        "minimum_scale_cvi_average_required",
        "all_required_facets_covered",
        "unresolved_construct_overlap_count",
        "unresolved_reading_level_count",
        "unresolved_harm_ethics_count"
      ],
      "properties": {
        "calculation_rule": {
          "type": "string",
          "minLength": 40
        },
        "scale_cvi_average": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "scale_cvi_universal_agreement": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "minimum_item_cvi_required": {
          "type": "number",
          "const": 0.78
        },
        "minimum_scale_cvi_average_required": {
          "type": "number",
          "const": 0.9
        },
        "all_required_facets_covered": {
          "type": "boolean"
        },
        "unresolved_construct_overlap_count": {
          "type": "integer",
          "minimum": 0
        },
        "unresolved_reading_level_count": {
          "type": "integer",
          "minimum": 0
        },
        "unresolved_harm_ethics_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "revision_decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item_id",
          "decision",
          "decision_rationale",
          "new_item_version_required",
          "resolved_before_scored_promotion"
        ],
        "properties": {
          "item_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(_[a-z0-9]+)*$"
          },
          "decision": {
            "type": "string",
            "enum": [
              "retain_without_revision",
              "retain_with_minor_revision",
              "major_revision_required",
              "exclude",
              "pending_review"
            ]
          },
          "decision_rationale": {
            "type": "string",
            "minLength": 20
          },
          "new_item_version_required": {
            "type": "boolean"
          },
          "resolved_before_scored_promotion": {
            "type": "boolean"
          }
        }
      }
    },
    "promotion_eligibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scored_promotion_eligible",
        "minimum_independent_reviewers_met",
        "all_item_cvi_thresholds_met",
        "scale_cvi_threshold_met",
        "construct_overlap_resolved",
        "reading_level_resolved",
        "harm_ethics_resolved",
        "eligibility_statement"
      ],
      "properties": {
        "scored_promotion_eligible": {
          "type": "boolean"
        },
        "minimum_independent_reviewers_met": {
          "type": "boolean"
        },
        "all_item_cvi_thresholds_met": {
          "type": "boolean"
        },
        "scale_cvi_threshold_met": {
          "type": "boolean"
        },
        "construct_overlap_resolved": {
          "type": "boolean"
        },
        "reading_level_resolved": {
          "type": "boolean"
        },
        "harm_ethics_resolved": {
          "type": "boolean"
        },
        "eligibility_statement": {
          "type": "string",
          "minLength": 40
        }
      }
    },
    "signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "content_validity_decision",
        "signed_by",
        "signed_date",
        "signoff_statement"
      ],
      "properties": {
        "content_validity_decision": {
          "type": "string",
          "enum": [
            "not_reviewed",
            "approved_for_psychometric_promotion_review",
            "approved_for_development_only",
            "blocked"
          ]
        },
        "signed_by": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(_[a-z0-9]+)*$"
          }
        },
        "signed_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "signoff_statement": {
          "type": "string",
          "minLength": 40
        }
      }
    }
  },
  "$defs": {
    "repository_path": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._/\\-]+$"
    },
    "resolution_flag": {
      "type": "string",
      "enum": [
        "none",
        "resolved",
        "unresolved",
        "pending_review"
      ]
    },
    "reviewer_rating": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewer_id",
        "relevance",
        "clarity",
        "facet_fit",
        "ethical_acceptability",
        "construct_overlap_flag",
        "reading_level_flag",
        "harm_ethics_flag",
        "comments"
      ],
      "properties": {
        "reviewer_id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(_[a-z0-9]+)*$"
        },
        "relevance": {
          "$ref": "#/$defs/rating_or_null"
        },
        "clarity": {
          "$ref": "#/$defs/rating_or_null"
        },
        "facet_fit": {
          "$ref": "#/$defs/rating_or_null"
        },
        "ethical_acceptability": {
          "$ref": "#/$defs/rating_or_null"
        },
        "construct_overlap_flag": {
          "$ref": "#/$defs/resolution_flag"
        },
        "reading_level_flag": {
          "$ref": "#/$defs/resolution_flag"
        },
        "harm_ethics_flag": {
          "$ref": "#/$defs/resolution_flag"
        },
        "comments": {
          "type": "string"
        }
      }
    },
    "rating_or_null": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1,
      "maximum": 4
    },
    "criterion_cvi": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relevance",
        "clarity",
        "facet_fit",
        "ethical_acceptability"
      ],
      "properties": {
        "relevance": {
          "$ref": "#/$defs/cvi_value"
        },
        "clarity": {
          "$ref": "#/$defs/cvi_value"
        },
        "facet_fit": {
          "$ref": "#/$defs/cvi_value"
        },
        "ethical_acceptability": {
          "$ref": "#/$defs/cvi_value"
        }
      }
    },
    "cvi_value": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    }
  }
}
