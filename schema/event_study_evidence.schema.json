{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anx-bench.org/schema/event_study_evidence.schema.json",
  "title": "ANX-Bench Wave 4 event-study evidence packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_study_evidence_schema_version",
    "evidence_id",
    "study_id",
    "benchmark_version",
    "source_scored_release",
    "construct_id",
    "score_name",
    "analysis_plan_schema_version",
    "analysis_plan_path",
    "preregistration_path",
    "event_registry_path",
    "frozen_item_ids",
    "frozen_item_versions",
    "locked_event_id",
    "registry_lock_proof",
    "analysis_windows",
    "sample_counts",
    "primary_estimate",
    "pretrend_check",
    "robustness_checks",
    "confounds",
    "claim_decision",
    "reported_claim_text"
  ],
  "properties": {
    "event_study_evidence_schema_version": {
      "type": "string",
      "const": "v0.1.0"
    },
    "evidence_id": {
      "type": "string",
      "minLength": 1
    },
    "study_id": {
      "type": "string",
      "const": "anx_us_2026w04_somatic_event_study"
    },
    "benchmark_version": {
      "type": "string",
      "const": "v0.4.0"
    },
    "source_scored_release": {
      "type": "string",
      "const": "v0.3.1"
    },
    "construct_id": {
      "type": "string",
      "const": "somatic_ambient_anxiety"
    },
    "score_name": {
      "type": "string",
      "const": "somatic_ambient_anxiety_mean"
    },
    "analysis_plan_schema_version": {
      "type": "string",
      "const": "v0.4.0"
    },
    "analysis_plan_path": {
      "type": "string",
      "const": "analysis/v0.4/somatic_event_study/wave4_event_study_analysis_plan.json"
    },
    "preregistration_path": {
      "type": "string",
      "const": "docs/preregistrations/anx_us_2026w04_somatic_event_study.md"
    },
    "event_registry_path": {
      "type": "string",
      "const": "events/v0.4/anx_us_2026w04_somatic_event_registry.template.json"
    },
    "frozen_item_ids": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "sleep_disruption_ai_news",
          "body_vigilance_model_release",
          "background_dread_ai_progress",
          "avoidance_after_ai_capability_demo"
        ]
      }
    },
    "frozen_item_versions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sleep_disruption_ai_news",
        "body_vigilance_model_release",
        "background_dread_ai_progress",
        "avoidance_after_ai_capability_demo"
      ],
      "properties": {
        "sleep_disruption_ai_news": {
          "type": "string",
          "const": "v0.2.0"
        },
        "body_vigilance_model_release": {
          "type": "string",
          "const": "v0.2.0"
        },
        "background_dread_ai_progress": {
          "type": "string",
          "const": "v0.2.0"
        },
        "avoidance_after_ai_capability_demo": {
          "type": "string",
          "const": "v0.2.0"
        }
      }
    },
    "locked_event_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "registry_lock_proof": {
      "$ref": "#/$defs/registry_lock_proof"
    },
    "analysis_windows": {
      "$ref": "#/$defs/analysis_windows"
    },
    "sample_counts": {
      "$ref": "#/$defs/sample_counts"
    },
    "primary_estimate": {
      "$ref": "#/$defs/estimate"
    },
    "pretrend_check": {
      "$ref": "#/$defs/pretrend_check"
    },
    "robustness_checks": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": {
        "$ref": "#/$defs/robustness_check"
      }
    },
    "confounds": {
      "$ref": "#/$defs/confounds"
    },
    "claim_decision": {
      "$ref": "#/$defs/claim_decision"
    },
    "reported_claim_text": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$defs": {
    "nullable_boolean": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "nullable_integer": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "nullable_number": {
      "type": [
        "number",
        "null"
      ]
    },
    "nullable_unit_number": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "sha256_or_null": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-f0-9]{64}$"
    },
    "registry_lock_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_version",
        "registry_status",
        "lock_date",
        "event_locked_before_outcome_inspection",
        "outcome_inspection_status",
        "registry_sha256",
        "event_record_sha256",
        "release_blocking_confound_present"
      ],
      "properties": {
        "registry_version": {
          "$ref": "#/$defs/nullable_string"
        },
        "registry_status": {
          "$ref": "#/$defs/nullable_string"
        },
        "lock_date": {
          "$ref": "#/$defs/nullable_string"
        },
        "event_locked_before_outcome_inspection": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "outcome_inspection_status": {
          "$ref": "#/$defs/nullable_string"
        },
        "registry_sha256": {
          "$ref": "#/$defs/sha256_or_null"
        },
        "event_record_sha256": {
          "$ref": "#/$defs/sha256_or_null"
        },
        "release_blocking_confound_present": {
          "$ref": "#/$defs/nullable_boolean"
        }
      }
    },
    "analysis_windows": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline_primary",
        "followup_primary",
        "excluded_event_buffer",
        "placebo_pretrend_early_pre",
        "placebo_pretrend_late_pre"
      ],
      "properties": {
        "baseline_primary": {
          "type": "string",
          "minLength": 1
        },
        "followup_primary": {
          "type": "string",
          "minLength": 1
        },
        "excluded_event_buffer": {
          "type": "string",
          "minLength": 1
        },
        "placebo_pretrend_early_pre": {
          "type": "string",
          "minLength": 1
        },
        "placebo_pretrend_late_pre": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sample_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline_primary_nominal_n",
        "followup_primary_nominal_n",
        "baseline_effective_weighted_n",
        "followup_effective_weighted_n",
        "analytic_exclusions_n",
        "weighting_sensitive"
      ],
      "properties": {
        "baseline_primary_nominal_n": {
          "$ref": "#/$defs/nullable_integer"
        },
        "followup_primary_nominal_n": {
          "$ref": "#/$defs/nullable_integer"
        },
        "baseline_effective_weighted_n": {
          "$ref": "#/$defs/nullable_number"
        },
        "followup_effective_weighted_n": {
          "$ref": "#/$defs/nullable_number"
        },
        "analytic_exclusions_n": {
          "$ref": "#/$defs/nullable_integer"
        },
        "weighting_sensitive": {
          "$ref": "#/$defs/nullable_boolean"
        }
      }
    },
    "estimate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coefficient_name",
        "coefficient",
        "standard_error",
        "ci_95_lower",
        "ci_95_upper",
        "p_value",
        "decision"
      ],
      "properties": {
        "coefficient_name": {
          "type": "string",
          "const": "beta_post_event"
        },
        "coefficient": {
          "$ref": "#/$defs/nullable_number"
        },
        "standard_error": {
          "$ref": "#/$defs/nullable_number"
        },
        "ci_95_lower": {
          "$ref": "#/$defs/nullable_number"
        },
        "ci_95_upper": {
          "$ref": "#/$defs/nullable_number"
        },
        "p_value": {
          "$ref": "#/$defs/nullable_unit_number"
        },
        "decision": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "pass",
            "fail",
            null
          ]
        }
      }
    },
    "pretrend_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coefficient_name",
        "coefficient",
        "ci_95_lower",
        "ci_95_upper",
        "p_value",
        "decision"
      ],
      "properties": {
        "coefficient_name": {
          "type": "string",
          "const": "late_pre_period"
        },
        "coefficient": {
          "$ref": "#/$defs/nullable_number"
        },
        "ci_95_lower": {
          "$ref": "#/$defs/nullable_number"
        },
        "ci_95_upper": {
          "$ref": "#/$defs/nullable_number"
        },
        "p_value": {
          "$ref": "#/$defs/nullable_unit_number"
        },
        "decision": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "pass",
            "fail",
            null
          ]
        }
      }
    },
    "robustness_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "coefficient",
        "ci_95_lower",
        "ci_95_upper",
        "p_value",
        "decision",
        "notes"
      ],
      "properties": {
        "check_id": {
          "type": "string",
          "minLength": 1
        },
        "coefficient": {
          "$ref": "#/$defs/nullable_number"
        },
        "ci_95_lower": {
          "$ref": "#/$defs/nullable_number"
        },
        "ci_95_upper": {
          "$ref": "#/$defs/nullable_number"
        },
        "p_value": {
          "$ref": "#/$defs/nullable_unit_number"
        },
        "decision": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "pass",
            "fail",
            "reported",
            null
          ]
        },
        "notes": {
          "$ref": "#/$defs/nullable_string"
        }
      }
    },
    "confounds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_blocking_confound_present",
        "competing_event_review",
        "adjudication_notes"
      ],
      "properties": {
        "release_blocking_confound_present": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "competing_event_review": {
          "$ref": "#/$defs/nullable_string"
        },
        "adjudication_notes": {
          "$ref": "#/$defs/nullable_string"
        }
      }
    },
    "claim_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_threshold_decision",
        "claim_authorized",
        "authorized_claim_language",
        "blocked_claims",
        "decision_notes"
      ],
      "properties": {
        "primary_threshold_decision": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "pass",
            "descriptive_only",
            null
          ]
        },
        "claim_authorized": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "authorized_claim_language": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "event-associated somatic anxiety change",
            "descriptive monitoring only",
            null
          ]
        },
        "blocked_claims": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "decision_notes": {
          "$ref": "#/$defs/nullable_string"
        }
      }
    }
  }
}
