    "result_id",
    "result_status",
    "study_id",
    "wave_id",
    "benchmark_version",
    "promotion_target_version",
    "event_id",
    "evidence_date",
    "outcome_inspection",
    "source_paths",
    "frozen_item_ids",
    "frozen_item_versions",
    "sample_exclusion_flow",
    "split_ids",
    "split_sample",
    "item_distributions",
    "domain_summaries",
    "model_output_pointers",
    "model_fit_outputs",
    "dif_invariance_summaries",
    "anchor_drift_outputs",
    "sensitivity_summaries",
    "claim_limits",
    "analyst_signoff",
    "reviewer_signoff"
