        "partner_ai_confidant_displacement": { "type": "string", "const": "v0.8.0" },
        "friend_group_ai_mediation": { "type": "string", "const": "v0.8.0" },
        "eldercare_ai_attachment_shift": { "type": "string", "const": "v0.8.0" },
        "ai_personhood_boundary_uncertainty": { "type": "string", "const": "v0.8.0" },
        "human_judgment_status_loss": { "type": "string", "const": "v0.8.0" },
        "life_purpose_ai_substitution": { "type": "string", "const": "v0.8.0" },
        "public_space_tracking": { "type": "string", "const": "v0.8.0" },
        "workplace_behavior_scoring": { "type": "string", "const": "v0.8.0" },
        "personalized_behavior_nudging": { "type": "string", "const": "v0.8.0" },
        "autonomous_cyber_cascade": { "type": "string", "const": "v0.8.0" },
