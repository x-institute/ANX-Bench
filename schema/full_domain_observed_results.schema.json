        "background_dread_ai_progress": { "type": "string", "const": "v0.2.0" },
        "avoidance_after_ai_capability_demo": { "type": "string", "const": "v0.2.0" },
        "skill_obsolescence_software": { "type": "string", "const": "v0.1.0" },
        "wage_pressure_customer_support": { "type": "string", "const": "v0.1.0" },
