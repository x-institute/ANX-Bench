{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anx-bench.org/schema/psychometric_evidence_manifest.schema.json",
  "title": "ANX-Bench Psychometric Evidence Manifest Schema",
  "description": "Machine-readable provenance manifest for scored-release psychometric evidence. The manifest binds preregistration, analysis plan, restricted data digest, analysis script digest, software lock, run metadata, analyst identity, and every reported validation statistic to reproducible output artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "evidence_manifest_schema_version",
    "manifest_id",
    "benchmark_version",
    "construct_id",
    "validation_dossier_path",
    "preregistration_path",
    "analysis_plan_path",
    "raw_restricted_dataset_hash",
    "analysis_script_hash",
    "software_session_lock",
    "run_timestamp_utc",
    "analyst",
    "output_artifact_hashes",
    "reported_statistic_map",
    "provenance_assertion"
  ],
  "properties": {
    "$schema": {
      "$ref": "#/$defs/repository_path"
    },
    "evidence_manifest_schema_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "manifest_id": {
      "$ref": "#/$defs/id"
    },
    "benchmark_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "construct_id": {
      "$ref": "#/$defs/id"
    },
    "validation_dossier_path": {
      "$ref": "#/$defs/repository_path"
    },
    "preregistration_path": {
      "$ref": "#/$defs/repository_path"
    },
    "analysis_plan_path": {
      "$ref": "#/$defs/repository_path"
    },
    "raw_restricted_dataset_hash": {
      "$ref": "#/$defs/hash_record"
    },
    "analysis_script_hash": {
      "$ref": "#/$defs/hash_record"
    },
    "software_session_lock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lock_artifact",
        "runtime",
        "packages",
        "session_info_sha256",
        "reproducibility_rule"
      ],
      "properties": {
        "lock_artifact": {
          "$ref": "#/$defs/repository_path_or_restricted"
        },
        "runtime": {
          "type": "string",
          "minLength": 3
        },
        "packages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "version"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "session_info_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "reproducibility_rule": {
          "type": "string",
          "minLength": 40
        }
      }
    },
    "run_timestamp_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "analyst": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "role",
        "affiliation",
        "independence_statement"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2
        },
        "role": {
          "type": "string",
          "minLength": 5
        },
        "affiliation": {
          "type": "string",
          "minLength": 2
        },
        "independence_statement": {
          "type": "string",
          "minLength": 30
        }
      }
    },
    "output_artifact_hashes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/output_artifact"
      }
    },
    "reported_statistic_map": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "statistic_id",
          "dossier_json_pointer",
          "analysis_family",
          "reported_value",
          "artifact_id",
          "artifact_json_pointer",
          "reproduction_command"
        ],
        "properties": {
          "statistic_id": {
            "$ref": "#/$defs/id"
          },
          "dossier_json_pointer": {
            "$ref": "#/$defs/json_pointer"
          },
          "analysis_family": {
            "type": "string",
            "enum": [
              "efa",
              "cfa",
              "reliability",
              "irt",
              "dif",
              "invariance",
              "external_validity",
              "retention"
            ]
          },
          "reported_value": {
            "type": "string",
            "minLength": 1
          },
          "artifact_id": {
            "$ref": "#/$defs/id"
          },
          "artifact_json_pointer": {
            "$ref": "#/$defs/json_pointer"
          },
          "reproduction_command": {
            "type": "string",
            "minLength": 20
          }
        }
      }
    },
    "provenance_assertion": {
      "type": "string",
      "minLength": 80
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(_[a-z0-9]+)*$"
    },
    "repository_path": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._/\\-]+$"
    },
    "repository_path_or_restricted": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:/\\-]+$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "hash_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "sha256",
        "artifact"
      ],
      "properties": {
        "algorithm": {
          "const": "SHA-256"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "artifact": {
          "$ref": "#/$defs/repository_path_or_restricted"
        }
      }
    },
    "output_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "path",
        "sha256",
        "description"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/id"
        },
        "path": {
          "$ref": "#/$defs/repository_path_or_restricted"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "description": {
          "type": "string",
          "minLength": 20
        }
      }
    },
    "json_pointer": {
      "type": "string",
      "pattern": "^(/[^/~]*(~[01][^/~]*)*)+$"
    }
  }
}
