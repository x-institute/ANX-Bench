  "construct_id": "full_domain_bridge_blueprint",
  "construct_definition": "The Wave 8 full-domain bridge blueprint covers the seven registered ANX-Bench domains as distinct but related facets of human psychological response to advancing AI capability: somatic and ambient, economic and vocational, epistemic, relational, existential and identity, autonomy and surveillance, and safety and catastrophic anxiety.",
  "intended_scored_use": "This preregistered template does not authorize scored use. It defines the content-validity review structure that must be completed before the Wave 8 full-domain bridge item set can support any later psychometric promotion review or scored-release proposal.",
  "target_population": "Non-institutionalized US adults age 18 or older completing an English-language online self-administered ANX-Bench survey under the Wave 8 no-event bridge protocol.",
  "review_protocol_path": "docs/content_validity_protocol.md",
